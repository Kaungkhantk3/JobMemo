generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  ASSESSMENT
  REJECTED
  OFFER
  GHOSTED
}

model Application {
  id        String            @id @default(cuid())
  company   String
  position  String
  jobUrl    String?
  notes     String?
  status    ApplicationStatus @default(SAVED)
  appliedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  events            ApplicationEvent[]
  gmailEmailReviews GmailEmailReview[]

  @@unique([userId, company, position])
  @@index([userId, status])
}

model ApplicationEvent {
  id            String   @id @default(cuid())
  applicationId String
  type          String
  title         String
  emailSubject  String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  applications      Application[]
  accounts          Account[]
  sessions          Session[]
  gmailEmailReviews GmailEmailReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GmailEmailReview {
  id String @id @default(cuid())

  userId              String
  gmailMessageId      String
  threadId            String?
  company             String?
  role                String?
  status              String?
  confidence          Int?
  hidden              Boolean   @default(false)
  userCorrectedStatus String?
  reviewed            Boolean   @default(false)
  source              String    @default("gmail")
  syncedAt            DateTime?
  notes               String?
  applicationId       String?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gmailMessageId])
  @@index([userId, hidden])
  @@index([userId, reviewed])
  @@index([userId, applicationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
